SUZIELAW_PORT=17501
SUZIELAW_PUBLIC_URL=http://localhost:17501
SUZIELAW_ALLOWED_ORIGIN=http://localhost:17502
SUZIELAW_TITLE=Suzie Law
SUZIELAW_AGENT_NAME=Counsel
SUZIELAW_AGENT_DESCRIPTION=Open-source legal assistant
# Default: Qwen via Alibaba Cloud Model Studio's OpenAI-compatible API.
# Other OpenAI-compatible providers work too; swap base URL + model together.
# Common DashScope base URLs:
#   International / Singapore: https://dashscope-intl.aliyuncs.com/compatible-mode
#   US / Virginia:             https://dashscope-us.aliyuncs.com/compatible-mode
SUZIELAW_AGENT_BASE_URL=http://localhost:11434/v1
SUZIELAW_MODEL=gpt-oss:20b
SUZIELAW_CLIENT_PORT=17502
# Optional
# SUZIELAW_AGENT_API_KEY=ollama

# Extra body params merged into every chat request (JSON object). Use for
# provider-specific knobs not in the OpenAI core spec.
# Qwen / Dashscope: suppress reasoning_content output:
SUZIELAW_AGENT_EXTRA_BODY={"enable_thinking":false}

# System prompt — short override. For long edits, change DEFAULT_SYSTEM_PROMPT in src/config.ts.
# SUZIELAW_SYSTEM_PROMPT="You are Counsel, ..."

# --- Locally-hosted model endpoints ---
# When the user picks a "Local" model in Settings, the chat call routes to
# these endpoints instead of SUZIELAW_AGENT_BASE_URL. Run each model on its
# own port (e.g. via vLLM, llama.cpp, or unsloth). API key blank if your
# server doesn't enforce auth.
# SUZIELAW_LOCAL_QWEN_BASE_URL=http://localhost:8801
# SUZIELAW_LOCAL_QWEN_API_KEY=
# SUZIELAW_LOCAL_GEMMA_BASE_URL=http://localhost:8802
# SUZIELAW_LOCAL_GEMMA_API_KEY=

# Tool use — built-in vector_search tool calls vector-db
SUZIELAW_VECTOR_DB_BASE_URL=http://localhost:3006
# SUZIELAW_VECTOR_DB_API_KEY=
# Cap on tool-use loop iterations (model -> tool -> model -> ...)
# Drafting workflows that write many sections will need 20+; document-Q&A or
# simple chat fits comfortably under 10.
SUZIELAW_TOOL_MAX_ITERATIONS=100

# Skills bridge — installed skill markdown is loaded into the system prompt at
# server start, and the http_request tool (allow-listed) lets the model call
# the URLs the skills describe.
#
# Local templates directory. Defaults to suzielaw's own ./skills (workflow
# recipes for legal tasks). Swap to ../../../open_teamsuzie/packages/skills/templates
# to load the upstream HTTP-API skills (documents, presentations, spreadsheets).
SUZIELAW_SKILLS_DIR=./skills

# Personas — file-based built-ins live here; user-created personas live in
# the SQLite db. Either source is optional; with both unset, only the default
# Counsel prompt is used.
SUZIELAW_PERSONAS_DIR=./personas

# --- Knowledge Base (lightweight RAG via sqlite-vec) ---
# When enabled: a "Knowledge Base" sidebar item appears, /api/kb endpoints
# come online, and the kb_search tool is registered with the agent. Backed
# by sqlite-vec on the same SQLite file as everything else. Embeddings come
# from an OpenAI-compatible /v1/embeddings endpoint — defaults reuse the
# chat agent's base URL + key. Pick a model + matching dim:
#   OpenAI       text-embedding-3-small   1536
#   OpenAI       text-embedding-3-large   3072
#   Dashscope    text-embedding-v3        1024
# SUZIELAW_KB_ENABLED=true
# SUZIELAW_KB_EMBEDDING_BASE_URL=        # default: SUZIELAW_AGENT_BASE_URL
# SUZIELAW_KB_EMBEDDING_API_KEY=         # default: SUZIELAW_AGENT_API_KEY
# SUZIELAW_KB_EMBEDDING_MODEL=text-embedding-3-small
# SUZIELAW_KB_EMBEDDING_DIM=1536
#
# Or point at a remote skill catalog:
# SUZIELAW_SKILL_CATALOG_URL=http://localhost:3021
# SUZIELAW_SKILL_CATALOG_TOKEN=
#
# Optional: limit which skills install. Empty = install all discovered.
# SUZIELAW_SKILLS_ALLOW=presentations

# {{TOKEN}} substitutions for skill markdown. Use the SUZIELAW_SKILL_VAR_
# prefix; the rest becomes the placeholder name. URL-shaped values automatically
# extend the http_request allow-list.
#
# To run the pptx-agent locally and let the assistant draft decks:
#   pnpm --dir ../open_teamsuzie dev:pptx-agent
# SUZIELAW_SKILL_VAR_PPTX_AGENT_URL=http://localhost:3009
# SUZIELAW_SKILL_VAR_AGENT_API_KEY=
# SUZIELAW_SKILL_VAR_AGENT_SLUG=suzielaw

# Extra hosts the http_request tool may call (comma-separated host:port).
# SUZIELAW_HTTP_ALLOWED_HOSTS=internal-api.example.com

# MCP — connect to external Model Context Protocol servers and expose their
# tools to the agent. Point at a JSON file using Claude Desktop's mcpServers
# shape.
# SUZIELAW_MCP_CONFIG=./mcp.json

# --- Auth (@teamsuzie/shared-auth: Postgres + Redis) ---
# Multi-user / multi-tenant auth lives in Postgres (users, orgs, sessions) and
# Redis (session store). For local dev:
#   docker compose -f docker/docker-compose.yml up -d
# brings up both on the ports below. In production, point these at managed
# instances and rotate SUZIELAW_SESSION_SECRET.
SUZIELAW_POSTGRES_URI=postgres://suzielaw:suzielaw@localhost:5433/suzielaw
SUZIELAW_REDIS_URI=redis://localhost:6380/0
# SUZIELAW_REDIS_KEY_PREFIX=suzielaw
# SUZIELAW_COOKIE_DOMAIN=
# SUZIELAW_POSTGRES_ENABLE_LOGGING=

# Demo user — seeded in Postgres on first boot when NODE_ENV=development. In
# production no user is auto-created; register via POST /api/auth/register.
SUZIELAW_DEMO_EMAIL=demo@example.com
SUZIELAW_DEMO_PASSWORD=demo
SUZIELAW_DEMO_NAME=Demo Lawyer
SUZIELAW_DEMO_ROLE=attorney
# Long random value in production. Session cookies are signed with this.
SUZIELAW_SESSION_SECRET=dev-only-suzielaw-secret
SUZIELAW_COOKIE_NAME=suzielaw.sid

# --- Stripe billing (@teamsuzie/billing-stripe) ---
# When SUZIELAW_STRIPE_SECRET_KEY is unset, billing is disabled: the routes
# still mount but every Stripe call throws, and the paywall middleware is
# replaced by a no-op so logged-in users can chat freely. Set the key (and
# rotate SUZIELAW_SESSION_SECRET) to enforce pay-to-use.
#
# In dev, point Stripe at your local webhook with:
#   stripe listen --forward-to http://localhost:17501/api/billing/webhook
# The CLI prints the webhook signing secret to paste below.
# SUZIELAW_STRIPE_SECRET_KEY=sk_test_...
# SUZIELAW_STRIPE_WEBHOOK_SECRET=whsec_...
#
# Pricing knobs (USD). All optional — defaults shown.
# SUZIELAW_BILLING_INITIAL_CREDITS=20
# SUZIELAW_BILLING_TOPUP_AMOUNT=20
# SUZIELAW_BILLING_LOW_BALANCE_THRESHOLD=5
# Per-1k-token deduction rate. Tune to your model pricing; set to 0 to
# require positive balance but never debit.
# SUZIELAW_BILLING_USD_PER_1K_TOKENS=0.01

# --- Hosted demo auth + token allowance ---
# Google/Microsoft OAuth use only `openid email profile`. Configure your own
# OAuth apps; do not commit client secrets. Redirect URIs default to:
#   ${SUZIELAW_PUBLIC_URL}/api/auth/google/callback
#   ${SUZIELAW_PUBLIC_URL}/api/auth/microsoft/callback
# SUZIELAW_GOOGLE_CLIENT_ID=
# SUZIELAW_GOOGLE_CLIENT_SECRET=
# SUZIELAW_GOOGLE_REDIRECT_URI=
# SUZIELAW_MICROSOFT_CLIENT_ID=
# SUZIELAW_MICROSOFT_CLIENT_SECRET=
# SUZIELAW_MICROSOFT_TENANT=common
# SUZIELAW_MICROSOFT_REDIRECT_URI=
#
# Per-account hosted-model allowance. 0 disables the cap. Token usage is
# counted from provider usage objects; Qwen/DashScope streaming calls request
# usage via stream_options.include_usage.
SUZIELAW_DEMO_TOKEN_LIMIT=50000
# Optional fallback if a provider omits usage data.
SUZIELAW_TOKEN_FALLBACK_PER_CALL=0

# --- Local SQLite (user prompts) ---
# Path is relative to the cwd the server starts from (apps/suzielaw/).
SUZIELAW_DB_PATH=./data/suzielaw.db

# --- File attachments ---
# Per-file size cap on the chat composer's attachment endpoint. Default 25MB.
# SUZIELAW_MAX_UPLOAD_BYTES=26214400

# --- Document templates ---
# Directory of `<id>.md` legal-document layouts (memorandum, opinion, agreement,
# brief, etc.). Each file has YAML frontmatter (id/title/description/document_type/
# when_to_use) followed by the markdown body. The list_templates / get_template
# tools surface the catalog to the model. Empty/unset disables the tools.
SUZIELAW_TEMPLATES_DIR=./templates

# --- CourtListener (case law / RECAP / citation lookup) ---
# Personal API token from https://www.courtlistener.com/profile/api/. The
# courtlistener_* tools work without it, but auth bumps the rate limit
# substantially. Sign-up is free.
# SUZIELAW_COURTLISTENER_TOKEN=

# --- markitdown-agent (DOCX/PDF ↔ markdown conversion + DOCX export) ---
# Sibling Python service. Provides convert_to_markdown, export_to_docx, and
# the document navigation/drafting tools. Started automatically by
# `pnpm dev:full` (handles venv + deps); for chat-only runs without DOCX
# tooling, comment this line out to skip the service entirely.
SUZIELAW_MARKITDOWN_AGENT_BASE_URL=http://localhost:3013
